# ============================================
# GRACE-X Brain API Configuration v2.1
# SECURITY HARDENED — v7.0.1-security-hardening
# ============================================
# Copy this file to .env and configure your settings
# NEVER commit your .env file to version control!
# ============================================

# ============================================
# PROVIDER SELECTION
# ============================================
# Choose your LLM provider: openai, anthropic, openrouter, ollama
LLM_PROVIDER=openai

# ============================================
# API KEYS (replace with your real keys)
# ============================================
# Generic API_KEY (used if provider-specific key not set)
API_KEY=replace_with_your_api_key

# Provider-specific keys (optional — override generic API_KEY)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# OPENROUTER_API_KEY=sk-or-...

# ============================================
# OPENAI SETTINGS
# ============================================
OPENAI_MODEL=gpt-4o-mini

# ============================================
# ANTHROPIC (CLAUDE) SETTINGS
# ============================================
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ============================================
# OPENROUTER SETTINGS
# ============================================
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# ============================================
# OLLAMA SETTINGS (LOCAL LLM)
# ============================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ============================================
# SERVER SETTINGS
# ============================================
PORT=3000
NODE_ENV=development
MAX_BODY_SIZE=1mb
REQUEST_TIMEOUT=30000

# ============================================
# AUTHENTICATION (REQUIRED)
# ============================================
# Generate hashes: node generate-hashes.js
# Then paste the output here.
#
JWT_SECRET=replace_with_long_random_secret_min_64_chars
AUTH_MASTER_HASH=replace_with_bcrypt_hash
AUTH_DEE_HASH=replace_with_bcrypt_hash
AUTH_GENERAL_HASH=replace_with_bcrypt_hash
AUTH_TOKEN_HASH=replace_with_bcrypt_hash_of_6digit_token
AUTH_PIN_HASHES=replace_with_bcrypt_hash_1,replace_with_bcrypt_hash_2

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=30

# ============================================
# CORS SETTINGS (restrict to known origins)
# ============================================
CORS_ORIGINS=http://localhost:8080,http://localhost:3000,http://127.0.0.1:8080

# ============================================
# LOGGING
# ============================================
ENABLE_LOGGING=true
LOG_LEVEL=info

# ============================================
# PRODUCTION SETTINGS
# ============================================
# NODE_ENV=production
# CORS_ORIGINS=https://your-production-domain.com
# APP_URL=https://your-production-domain.com
